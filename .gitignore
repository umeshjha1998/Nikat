# Nikat - Root .gitignore

# OS files
.DS_Store
Thumbs.db
*.lnk

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backend (Maven)
**/target/
**/apache-maven-*/
**/*.jar
**/*.war
**/*.ear
**/*.zip
**/*.tar.gz
**/*.rar
.mvn/

# Frontend (Angular/Node)
**/node_modules/
**/dist/
**/.angular/
**/.vscode/
**/.idea/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/
frontend/coverage/

# IDE files
*.swp
*.bak
*~
.history/
